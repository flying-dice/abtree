{
  "name": "@abtree/serve",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "schema": "bun scripts/schema.ts openapi.json",
    "orval": "bun run schema && orval --config orval.config.ts",
    "tsc": "tsc",
    "dev": "ABTREE_SERVE_PATH=${ABTREE_SERVE_PATH:-../../.abtree/executions} bun --hot src/dev.ts",
    "start": "NODE_ENV=production bun src/dev.ts",
    "build": "bun run build.ts"
  },
  "dependencies": {
    "@abtree/runtime": "workspace:*",
    "@hono/standard-validator": "^0.2.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@scalar/hono-api-reference": "^0.10.14",
    "@xyflow/react": "^12.3.5",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.18",
    "hono-openapi": "^1.3.0",
    "http-status-codes": "^2.3.0",
    "lucide-react": "^1",
    "react": "^19",
    "react-dom": "^19",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "orval": "^8.9.1",
    "tailwindcss": "^4.1.11"
  }
}
