{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://abtree.sh/schemas/tree.schema.json",
	"title": "abtree Tree File",
	"description": "Schema for abtree behaviour-tree YAML files. Reference via `# yaml-language-server: $schema=...` or `$schema:` field.",
	"type": "object",
	"properties": {
		"$schema": {
			"type": "string"
		},
		"name": {
			"type": "string",
			"minLength": 1
		},
		"version": {
			"type": "string"
		},
		"description": {
			"type": "string"
		},
		"state": {
			"type": "object",
			"properties": {
				"local": {
					"type": "object",
					"propertyNames": {
						"type": "string"
					},
					"additionalProperties": {}
				},
				"global": {
					"type": "object",
					"propertyNames": {
						"type": "string"
					},
					"additionalProperties": {}
				}
			},
			"additionalProperties": false
		},
		"tree": {
			"$ref": "#/$defs/__schema0"
		}
	},
	"required": ["name", "version", "tree"],
	"additionalProperties": false,
	"$defs": {
		"__schema0": {
			"anyOf": [
				{
					"type": "object",
					"properties": {
						"$ref": {
							"type": "string"
						}
					},
					"required": ["$ref"],
					"additionalProperties": false
				},
				{
					"type": "object",
					"properties": {
						"type": {
							"type": "string",
							"const": "action"
						},
						"name": {
							"type": "string",
							"minLength": 1
						},
						"steps": {
							"minItems": 1,
							"type": "array",
							"items": {
								"anyOf": [
									{
										"type": "object",
										"properties": {
											"evaluate": {
												"type": "string",
												"minLength": 1
											}
										},
										"required": ["evaluate"],
										"additionalProperties": false
									},
									{
										"type": "object",
										"properties": {
											"instruct": {
												"type": "string",
												"minLength": 1
											}
										},
										"required": ["instruct"],
										"additionalProperties": false
									}
								]
							}
						},
						"retries": {
							"type": "integer",
							"minimum": 1,
							"maximum": 9007199254740991
						}
					},
					"required": ["type", "name", "steps"],
					"additionalProperties": false
				},
				{
					"type": "object",
					"properties": {
						"type": {
							"type": "string",
							"enum": ["sequence", "selector", "parallel"]
						},
						"name": {
							"type": "string",
							"minLength": 1
						},
						"children": {
							"minItems": 1,
							"type": "array",
							"items": {
								"$ref": "#/$defs/__schema0"
							}
						},
						"retries": {
							"type": "integer",
							"minimum": 1,
							"maximum": 9007199254740991
						}
					},
					"required": ["type", "name", "children"],
					"additionalProperties": false
				}
			]
		}
	}
}
