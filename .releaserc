{
  "branches": ["main"],
  "repositoryUrl": "https://github.com/flying-dice/abtree.git",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "angular",
        "releaseRules": [
          { "breaking": true, "release": "minor" }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bun run schema && bun packages/cli/scripts/build.ts --all && sed -i.bak 's|:-__ABTREE_VERSION__}|:-${nextRelease.gitTag}}|' install.sh && sed -i.bak 's|Version = \"__ABTREE_VERSION__\"|Version = \"${nextRelease.gitTag}\"|' install.ps1 && rm -f install.sh.bak install.ps1.bak && for f in trees/*/package.json packages/dsl/package.json; do sed -i.bak -E 's/\"version\": \"[^\"]+\"/\"version\": \"${nextRelease.version}\"/' \"$f\"; done && rm -f trees/*/package.json.bak packages/dsl/package.json.bak",
        "publishCmd": "set -e; (cd packages/dsl && bun publish --access=public); for d in trees/*/; do (cd \"$d\" && bun publish --access=public); done"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "abtree-linux-x64",      "label": "abtree-linux-x64" },
          { "path": "abtree-linux-arm64",     "label": "abtree-linux-arm64" },
          { "path": "abtree-darwin-x64",      "label": "abtree-darwin-x64" },
          { "path": "abtree-darwin-arm64",    "label": "abtree-darwin-arm64" },
          { "path": "abtree-windows-x64.exe", "label": "abtree-windows-x64.exe" },
          { "path": "install.sh",             "label": "install.sh" },
          { "path": "install.ps1",            "label": "install.ps1" },
          { "path": "SKILL.md",               "label": "SKILL.md" },
          { "path": "tree.schema.json",       "label": "tree.schema.json" }
        ]
      }
    ]
  ]
}
