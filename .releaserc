{
  "branches": ["main"],
  "repositoryUrl": "https://github.com/flying-dice/abtree.git",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bun scripts/generate-schema.ts && bun build --compile --target=bun-linux-x64 index.ts --outfile=abtree-linux-x64 && bun build --compile --target=bun-linux-arm64 index.ts --outfile=abtree-linux-arm64 && bun build --compile --target=bun-darwin-x64 index.ts --outfile=abtree-darwin-x64 && bun build --compile --target=bun-darwin-arm64 index.ts --outfile=abtree-darwin-arm64 && bun build --compile --target=bun-windows-x64 index.ts --outfile=abtree-windows-x64.exe"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "abtree-linux-x64",      "label": "abtree-linux-x64" },
          { "path": "abtree-linux-arm64",     "label": "abtree-linux-arm64" },
          { "path": "abtree-darwin-x64",      "label": "abtree-darwin-x64" },
          { "path": "abtree-darwin-arm64",    "label": "abtree-darwin-arm64" },
          { "path": "abtree-windows-x64.exe", "label": "abtree-windows-x64.exe" },
          { "path": "install.sh",             "label": "install.sh" },
          { "path": "install.ps1",            "label": "install.ps1" },
          { "path": "SKILL.md",               "label": "SKILL.md" },
          { "path": "tree.schema.json",       "label": "tree.schema.json" }
        ]
      }
    ]
  ]
}
