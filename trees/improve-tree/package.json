{
	"name": "@abtree/improve-tree",
	"version": "0.1.0",
	"description": "Score the effectiveness of a tree using evidence from one of its sessions, find improvements in parallel, draft a plan in plans/, then commit and push.",
	"main": "main.json",
	"homepage": "https://github.com/flying-dice/abtree/tree/main/trees/improve-tree",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/flying-dice/abtree.git",
		"directory": "trees/improve-tree"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"main.json",
		"tree.svg",
		"tests"
	],
	"scripts": {
		"build": "bun scripts/build.ts",
		"prepublishOnly": "bun run build"
	},
	"keywords": [
		"abtree",
		"behaviour-tree",
		"bt",
		"improve"
	],
	"devDependencies": {
		"@abtree/dsl": "workspace:*",
		"@abtree/runtime": "workspace:*"
	}
